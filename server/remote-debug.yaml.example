# Remote debug profile — copy to remote-debug.yaml and fill in your values.
# NEVER commit remote-debug.yaml (hostnames, tunnel IPs, secrets).
#
# Architecture:
#   • Remote debug server: LiveKit + Traefik + devcli tunnel agent
#   • Local machine: API (air) + web (vite HMR over public wss via Traefik)
#   • Local devcli connects outbound to server agent; Traefik routes
#     public traffic to your local api/web over the tunnel
#   • Opt out of web HMR mid-call: BEDRUD_HMR=0 in the environment
#
# Workflow:
#   devcli remote tunnel deploy     # install agent on server (once)
#   devcli remote run --yes
#
# SSH credentials: server/.env (copy from server/.env.example)
#   REMOTE_DEBUG_SSH_HOST, REMOTE_DEBUG_SSH_USER, REMOTE_DEBUG_TUNNEL_TOKEN,
#   REMOTE_DEBUG_TUNNEL_TLS_FINGERPRINT

tunnel:
  mode: devtunnel
  devtunnel:
    port: 7079
    # tlsFingerprint: from REMOTE_DEBUG_TUNNEL_TLS_FINGERPRINT in server/.env

urls:
  publicHost: debug.example.com
  publicBase: https://debug.example.com
  # Browser WebSocket — always the REMOTE server (Traefik → LiveKit :7072).
  livekitHost: wss://debug.example.com/livekit
  # Local API → remote LiveKit HTTP API via devtunnel proxy
  # livekitInternal: http://127.0.0.1:17072

local:
  webPort: 7070
  apiPort: 7071

livekit:
  apiKey: devkey
  # apiSecret: from REMOTE_DEBUG_LIVEKIT_API_SECRET in server/.env

traefik:
  dynamicDir: /etc/traefik/dynamic/bedrud-debug
  entryPoint: websecure
  livekitPort: 7072

provision:
  stateDir: /etc/bedrud-debug
  livekitRTCPort: 7073
  livekitRTCStart: 7080
  livekitRTCEnd: 7099
  enableACME: true
  # acmeEmail: you@example.com   # or set REMOTE_DEBUG_ACME_EMAIL in server/.env

# Legacy tunnel modes (not recommended):
#
# tunnel:
#   mode: ssh
#   ssh:
#     remoteWebPort: 7070
#     remoteAPIPort: 7071
#     localLiveKitPort: 17072
#
# tunnel:
#   mode: wireguard
# wireguard:
#   configFile: ~/.config/wireguard/bedrud-debug.conf
#   localTunnelIP: 10.0.0.2
#   remoteTunnelIP: 10.0.0.1