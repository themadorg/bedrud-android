# Copy this file to config.local.yaml and fill in your values.
# NEVER commit config.local.yaml — it contains secrets.
server:
  port: "7071"
  httpPort: ""  # HTTP listener when TLS enabled. Default: "80". Unprivileged: "8080". Env: SERVER_HTTP_PORT
  host: "0.0.0.0"
  readTimeout: 30
  writeTimeout: 30
  # Self-signed cert key algorithm: "ed25519" (default, recommended),
  # "ecdsa256", "rsa2048", or "rsa4096". Only applies to cert generation;
  # renewal auto-detects and preserves the existing cert's algorithm.
  # Env: SERVER_CERT_ALGORITHM
  certAlgorithm: "ed25519"
  # maxParticipantsLimit sets the hard ceiling for room capacity (default: 1000, 0 = unlimited).
  # Env: SERVER_MAX_PARTICIPANTS_LIMIT
  maxParticipantsLimit: 1000
  # maxRoomsPerUser caps active rooms per user (default: 100, 0 = unlimited).
  # Env: SERVER_MAX_ROOMS_PER_USER
  maxRoomsPerUser: 100

database:
  type: "sqlite"
  path: "./bedrud-local.db"

logger:
  level: "debug"  # Log level: debug, info, warn, error. Controls both app and SQL query logs.
  outputPath: "" # Log to stdout

livekit:
  # Browser signaling URL. Connect directly to LiveKit (avoids Vite/Bun WS proxy breaking /rtc/v1/validate).
  # Production behind reverse proxy: use your public URL with /livekit path instead.
  host: "ws://localhost:7072"
  internalHost: "http://127.0.0.1:7072"
  apiKey: "devkey"
  apiSecret: "CHANGE_ME_LIVEKIT_SECRET"
  # configPath: "/etc/bedrud/livekit.yaml"  # External LiveKit YAML. Env: LIVEKIT_CONFIG_PATH
  # When TLS is enabled (enableTLS: true), TURN/TLS is auto-configured using server certs.
  #
  # Webhook (disconnect detection):
  #   Embedded LiveKit auto-configures webhook URL -> local API.
  #   External LiveKit: configure webhook URL in your LiveKit dashboard:
  #     https://<your-domain>/api/livekit/webhook
  #   Uses same apiKey/apiSecret for JWT signing.

auth:
  jwtSecret: "CHANGE_ME_32_CHAR_RANDOM_STRING!"
  sessionSecret: "CHANGE_ME_32_CHAR_RANDOM_STRING!"
  tokenDuration: 24
  passkeyChallengeTTL: 5  # passkey challenge expiry in minutes. Env: AUTH_PASSKEY_CHALLENGE_TTL
  # requireEmailVerification gates all local registration + login behind email verification.
  # Users must verify their email before accessing the app. Requires SMTP configuration.
  # Default: false (backward compatible). Env: AUTH_REQUIRE_EMAIL_VERIFICATION
  requireEmailVerification: false
  # verificationEmailCooldownMins controls min time between verification email resends.
  # Default: 2 minutes. Env: AUTH_VERIFICATION_COOLDOWN_MINS
  verificationEmailCooldownMins: 2
  # verificationTokenTTLHours controls how long verification links remain valid.
  # Default: 24 hours. Env: AUTH_VERIFICATION_TOKEN_TTL_HOURS
  verificationTokenTTLHours: 24
  # unverifiedAccountTTLHours controls automatic deletion of local/passkey accounts
  # that registered but never verified. 0 = disabled. Default: 48 hours.
  # Env: AUTH_UNVERIFIED_ACCOUNT_TTL_HOURS
  unverifiedAccountTTLHours: 48
  frontendURL: "http://localhost:7070"
  google:
    clientId: "CHANGE_ME_GOOGLE_CLIENT_ID"
    clientSecret: "CHANGE_ME_GOOGLE_CLIENT_SECRET"
    redirectUrl: "http://localhost:7071/api/auth/google/callback"
  github:
    clientId: "CHANGE_ME_GITHUB_CLIENT_ID"
    clientSecret: "CHANGE_ME_GITHUB_CLIENT_SECRET"
    redirectUrl: "http://localhost:7071/api/auth/github/callback"
  twitter:
    clientId: ""
    clientSecret: ""
    redirectUrl: "http://localhost:7071/api/auth/twitter/callback"

rateLimit:
  authMaxRequests: 10    # Max auth requests per window (login, register, refresh, passkey). 0 = disable
  authWindowSecs: 60     # Auth rate limit window in seconds
  guestMaxRequests: 5    # Max guest join requests per window. 0 = disable
  guestWindowSecs: 60    # Guest rate limit window in seconds

cors:
  allowedOrigins: "http://localhost:7070,http://localhost:7071"
  allowedHeaders: "Origin, Content-Type, Accept, Authorization"
  allowedMethods: "GET, POST, PUT, DELETE, OPTIONS"
  allowCredentials: true

chat:
  maxUploadBytesPerUser: 524288000  # Per-user upload quota (500 MB). 0 = unlimited. Env: CHAT_MAX_UPLOAD_BYTES_PER_USER
  globalDiskThresholdBytes: 0       # Global storage ceiling across all users. 0 = unlimited. Env: CHAT_GLOBAL_DISK_THRESHOLD_BYTES
  maxMessageCount: 10000            # Max chat messages kept per room (0 = unlimited). Env: CHAT_MAX_MESSAGE_COUNT
  messageTTLHours: 2160             # Purge messages older than this (0 = forever). 2160 = 90 days. Env: CHAT_MESSAGE_TTL_HOURS

queue:
  pollInterval: 500    # ms between polls. Env: QUEUE_POLL_INTERVAL
  maxAttempts: 3       # retries before failed. Env: QUEUE_MAX_ATTEMPTS
  concurrency: 1       # worker goroutines. Env: QUEUE_CONCURRENCY

recording:
  maxFileSizeMB: 2048          # Max file per recording (MB). 0 = unlimited
  storageDir: "./data/recordings" # Disk storage path
  maxRecordingsPerRoom: 0      # Limit per room. 0 = unlimited
  retentionHours: 720          # Keep recordings after room end (hours, 0=forever). Default 720 (30d). Env: RECORDING_RETENTION_HOURS
  cleanupIntervalHours: 24     # Scheduler check interval (hours, 0=disabled). Default 24. Env: RECORDING_CLEANUP_INTERVAL_HOURS

email:
  smtpHost: ""         # e.g. smtp.sendgrid.net. Env: EMAIL_SMTP_HOST
  smtpPort: 587        # Env: EMAIL_SMTP_PORT
  username: ""         # Env: EMAIL_USERNAME
  password: ""         # Env: EMAIL_PASSWORD
  fromAddress: ""      # e.g. noreply@bedrud.org. Env: EMAIL_FROM_ADDRESS
  fromName: "Bedrud"   # Env: EMAIL_FROM_NAME
  tlsSkipVerify: false # Skip TLS cert validation for self-signed SMTP. Env: EMAIL_TLS_SKIP_VERIFY
  smtpsMode: false     # Direct TLS (SMTPS, port 465). Env: EMAIL_SMTPS_MODE
