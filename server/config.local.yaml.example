# Copy this file to config.local.yaml and fill in your values.
# NEVER commit config.local.yaml — it contains secrets.
server:
  port: "8090"
  httpPort: ""  # HTTP listener when TLS enabled. Default: "80". Unprivileged: "8080". Env: SERVER_HTTP_PORT
  host: "0.0.0.0"
  readTimeout: 30
  writeTimeout: 30
  # Self-signed cert key algorithm: "ed25519" (default, recommended),
  # "ecdsa256", "rsa2048", or "rsa4096". Only applies to cert generation;
  # renewal auto-detects and preserves the existing cert's algorithm.
  # Env: SERVER_CERT_ALGORITHM
  certAlgorithm: "ed25519"

database:
  type: "sqlite"
  path: "./bedrud-local.db"

logger:
  level: "debug"  # Log level: debug, info, warn, error. Controls both app and SQL query logs.
  outputPath: "" # Log to stdout

livekit:
  host: "http://localhost:8090/livekit"
  internalHost: "http://127.0.0.1:7880"
  apiKey: "devkey"
  apiSecret: "CHANGE_ME_LIVEKIT_SECRET"
  # configPath: "/etc/bedrud/livekit.yaml"  # External LiveKit YAML. Env: LIVEKIT_CONFIG_PATH
  # When TLS is enabled (enableTLS: true), TURN/TLS is auto-configured using server certs.

auth:
  jwtSecret: "CHANGE_ME_32_CHAR_RANDOM_STRING"
  sessionSecret: "CHANGE_ME_32_CHAR_RANDOM_STRING"
  tokenDuration: 24
  frontendURL: "http://localhost:8090"
  google:
    clientId: "CHANGE_ME_GOOGLE_CLIENT_ID"
    clientSecret: "CHANGE_ME_GOOGLE_CLIENT_SECRET"
    redirectUrl: "http://localhost:8090/api/auth/google/callback"
  github:
    clientId: "CHANGE_ME_GITHUB_CLIENT_ID"
    clientSecret: "CHANGE_ME_GITHUB_CLIENT_SECRET"
    redirectUrl: "http://localhost:8090/api/auth/github/callback"
  twitter:
    clientId: ""
    clientSecret: ""
    redirectUrl: "http://localhost:8090/api/auth/twitter/callback"

rateLimit:
  authMaxRequests: 10    # Max auth requests per window (login, register, refresh, passkey). 0 = disable
  authWindowSecs: 60     # Auth rate limit window in seconds
  guestMaxRequests: 5    # Max guest join requests per window. 0 = disable
  guestWindowSecs: 60    # Guest rate limit window in seconds

cors:
  allowedOrigins: "http://localhost:8090,http://localhost:3000,http://localhost:5173"
  allowedHeaders: "Origin, Content-Type, Accept, Authorization"
  allowedMethods: "GET, POST, PUT, DELETE, OPTIONS"
  allowCredentials: true
