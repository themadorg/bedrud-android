# Copy to .env — NEVER commit .env (contains SSH credentials).
# Used by devcli remote (SSH to the debug server).
#
# Architecture:
#   Server (example.com): devcli tunnel agent + Traefik + LiveKit
#   Local machine:          Vite :7070 + API :7071 (hot reload)
#   Traefik routes / and /api to your local ports via devtunnel;
#   /livekit stays on the server.

REMOTE_DEBUG_SSH_HOST=example.com
REMOTE_DEBUG_SSH_USER=root
REMOTE_DEBUG_SSH_PORT=22
REMOTE_DEBUG_SSH_IDENTITY_FILE=~/.ssh/id_ed25519

# Public domain (DNS A record → server IP, grey-cloud / DNS-only)
REMOTE_DEBUG_PUBLIC_HOST=example.com

# devtunnel shared secret (generated by: devcli remote tunnel deploy)
REMOTE_DEBUG_TUNNEL_TOKEN=

# devtunnel TLS cert SHA-256 pin (generated by: devcli remote tunnel deploy)
REMOTE_DEBUG_TUNNEL_TLS_FINGERPRINT=

# WireGuard client endpoint (legacy wireguard mode only)
REMOTE_DEBUG_WG_ENDPOINT=example.com:51820

# LiveKit API secret (must match remote server; generated on first provision if empty)
REMOTE_DEBUG_LIVEKIT_API_SECRET=

# Let's Encrypt email for Traefik TLS (required when provision.enableACME is true)
# Required when remote-debug.yaml provision.enableACME: true
REMOTE_DEBUG_ACME_EMAIL=you@example.com