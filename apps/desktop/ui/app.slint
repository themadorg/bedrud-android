import { theme } from "theme.slint";
import { Button, ButtonVariant } from "components/button.slint";
import { Input } from "components/input.slint";
import { LoginScreen } from "auth/login.slint";
import { RegisterScreen } from "auth/register.slint";
import { RoomData } from "dashboard/room_card.slint";
import { DashboardScreen } from "dashboard/dashboard.slint";
import { ParticipantData } from "meeting/participant_tile.slint";
import { ChatMessage } from "meeting/chat_panel.slint";
import { MeetingScreen } from "meeting/meeting.slint";
import { AdminUserRow } from "admin/user_table.slint";
import { AdminScreen } from "admin/admin.slint";
import { SettingsScreen } from "settings.slint";

export enum NavScreen { AddInstance, Login, Register, Dashboard, Meeting, Admin, Settings, Instances }

export struct InstanceData {
    id: string,
    label: string,
    base-url: string,
    is-active: bool,
}

export component AppWindow inherits Window {
    title: "Bedrud";
    preferred-width: 1024px;
    preferred-height: 768px;
    min-width: 800px;
    min-height: 600px;
    background: theme.bg-primary;

    // Navigation
    in-out property <NavScreen> current-screen: NavScreen.Login;

    // Login
    in property <string> instance-url: "";
    in property <string> login-error: "";
    in property <bool> login-loading: false;

    // Dashboard
    in property <[RoomData]> rooms: [];
    in property <string> user-name: "";
    in property <bool> dashboard-loading: false;
    in property <bool> is-admin: false;

    // Meeting
    in property <[ParticipantData]> participants: [];
    in property <[ChatMessage]> chat-messages: [];
    in property <bool> mic-enabled: true;
    in property <bool> cam-enabled: false;
    in property <bool> is-creator: false;
    in property <string> meeting-room-name: "";
    in-out property <bool> chat-open: false;

    // Admin
    in property <[AdminUserRow]> admin-users: [];
    in property <int> online-count: 0;

    // Settings
    in property <[string]> mic-devices: [];
    in property <[string]> speaker-devices: [];
    in-out property <string> selected-mic: "";
    in-out property <string> selected-speaker: "";
    in-out property <int> noise-suppression-index: 0;
    in-out property <bool> echo-cancellation: true;

    // Add-instance form state
    in-out property <string> add-instance-label;
    in-out property <string> add-instance-url;
    in property <string> add-instance-error;

    // Instance list
    in property <[InstanceData]> instance-list: [];

    // Callbacks (wired from bridge.rs)
    callback add-instance(string, string);
    callback switch-instance(string);
    callback delete-instance(string);
    callback load-instances;
    callback login(string, string);
    callback passkey-login;
    callback guest-login(string);
    callback register(string, string, string, string);
    callback logout;
    callback join-room(string);
    callback create-room(string, bool, int);
    callback delete-room(string);
    callback end-call;
    callback toggle-mic;
    callback toggle-cam;
    callback send-chat(string);
    callback load-rooms;
    callback navigate-to(NavScreen);
    callback save-settings;
    callback settings-changed;

    if current-screen == NavScreen.Login: LoginScreen {
        width: parent.width; height: parent.height;
        instance-url: instance-url;
        error-message: login-error;
        loading: login-loading;
        login-clicked(email, pass) => { login(email, pass); }
        passkey-clicked => { passkey-login(); }
        guest-clicked => { guest-login(""); }
        register-clicked => { navigate-to(NavScreen.Register); }
    }

    if current-screen == NavScreen.Register: RegisterScreen {
        width: parent.width; height: parent.height;
        back-clicked => { navigate-to(NavScreen.Login); }
        register-clicked(email, name, pass, token) => { register(email, name, pass, token); }
    }

    if current-screen == NavScreen.Dashboard: DashboardScreen {
        width: parent.width; height: parent.height;
        rooms: rooms;
        user-name: user-name;
        loading: dashboard-loading;
        is-admin: is-admin;
        create-room-clicked => { create-room("", false, 20); }
        join-room-clicked(name) => { join-room(name); }
        delete-room-clicked(id) => { delete-room(id); }
        settings-clicked => { navigate-to(NavScreen.Settings); }
        admin-clicked => { navigate-to(NavScreen.Admin); }
        logout-clicked => { logout(); }
        instance-switch-clicked => { load-instances(); navigate-to(NavScreen.Instances); }
    }

    if current-screen == NavScreen.Meeting: MeetingScreen {
        width: parent.width; height: parent.height;
        participants: participants;
        chat-messages: chat-messages;
        mic-enabled: mic-enabled;
        cam-enabled: cam-enabled;
        is-creator: is-creator;
        room-name: meeting-room-name;
        chat-open <=> chat-open;
        toggle-mic => { toggle-mic(); }
        toggle-cam => { toggle-cam(); }
        end-call => { end-call(); }
        send-chat(msg) => { send-chat(msg); }
    }

    if current-screen == NavScreen.Admin: AdminScreen {
        width: parent.width; height: parent.height;
        users: admin-users;
        online-count: online-count;
        loading: dashboard-loading;
        back-clicked => { navigate-to(NavScreen.Dashboard); }
    }

    if current-screen == NavScreen.Instances: Rectangle {
        width: parent.width; height: parent.height;
        background: theme.bg-primary;

        VerticalLayout {
            // Toolbar
            Rectangle {
                height: 56px;
                background: theme.bg-secondary;
                border-width: 1px;
                border-color: theme.border;

                HorizontalLayout {
                    padding-left: theme.space-md;
                    padding-right: theme.space-md;
                    spacing: theme.space-sm;

                    Button {
                        text: "← Back";
                        variant: ButtonVariant.secondary;
                        height: 32px;
                        clicked => { navigate-to(NavScreen.Dashboard); }
                    }

                    Text {
                        text: "Instances";
                        font-size: theme.font-lg;
                        font-weight: 700;
                        color: theme.text-primary;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Button {
                        text: "+ Add";
                        height: 32px;
                        clicked => { navigate-to(NavScreen.AddInstance); }
                    }
                }
            }

            // Instance list
            VerticalLayout {
                vertical-stretch: 1;
                padding: theme.space-lg;
                spacing: theme.space-sm;

                if instance-list.length == 0: Text {
                    text: "No instances configured.";
                    color: theme.text-muted;
                    horizontal-alignment: center;
                }

                for inst in instance-list: Rectangle {
                    height: 64px;
                    background: inst.is-active ? theme.bg-hover : theme.bg-card;
                    border-radius: theme.radius-md;
                    border-width: 1px;
                    border-color: inst.is-active ? theme.accent : theme.border;

                    HorizontalLayout {
                        padding-left: theme.space-md;
                        padding-right: theme.space-md;
                        spacing: theme.space-md;

                        // Active indicator
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            y: (parent.height - self.height) / 2;
                            border-radius: 4px;
                            background: inst.is-active ? theme.success : theme.text-muted;
                        }

                        // Info
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 2px;

                            Text {
                                text: inst.label;
                                color: theme.text-primary;
                                font-size: theme.font-base;
                                font-weight: 500;
                            }
                            Text {
                                text: inst.base-url;
                                color: theme.text-secondary;
                                font-size: theme.font-sm;
                            }
                        }

                        // Actions
                        if !inst.is-active: Button {
                            text: "Switch";
                            variant: ButtonVariant.secondary;
                            height: 32px;
                            clicked => { switch-instance(inst.id); }
                        }
                        if !inst.is-active: Button {
                            text: "Remove";
                            variant: ButtonVariant.destructive;
                            height: 32px;
                            clicked => { delete-instance(inst.id); }
                        }
                        if inst.is-active: Text {
                            text: "Active";
                            color: theme.success;
                            font-size: theme.font-sm;
                            font-weight: 500;
                            vertical-alignment: center;
                        }
                    }

                    // Click to switch
                    TouchArea {
                        clicked => {
                            if !inst.is-active { switch-instance(inst.id); }
                        }
                    }
                }
            }
        }
    }

    if current-screen == NavScreen.Settings: SettingsScreen {
        width: parent.width; height: parent.height;
        mic-devices: mic-devices;
        speaker-devices: speaker-devices;
        selected-mic <=> selected-mic;
        selected-speaker <=> selected-speaker;
        noise-suppression-index <=> noise-suppression-index;
        echo-cancellation <=> echo-cancellation;
        back-clicked => { navigate-to(NavScreen.Dashboard); }
        save-clicked => { save-settings(); }
        settings-changed => { settings-changed(); }
    }

    if current-screen == NavScreen.AddInstance: Rectangle {
        width: parent.width; height: parent.height;
        background: theme.bg-primary;

        // Card
        Rectangle {
            width: 440px;
            height: card-layout.preferred-height + 80px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: theme.bg-secondary;
            border-radius: theme.radius-lg;
            border-width: 1px;
            border-color: theme.border;

            card-layout := VerticalLayout {
                alignment: center;
                spacing: theme.space-md;
                padding-left: theme.space-xl;
                padding-right: theme.space-xl;
                padding-top: 40px;
                padding-bottom: 40px;

                // Icon circle
                Rectangle {
                    height: 56px;
                    width: 56px;
                    x: (parent.width - self.width - theme.space-xl * 2) / 2;
                    background: theme.accent;
                    border-radius: 28px;

                    Text {
                        text: "B";
                        font-size: theme.font-xl;
                        font-weight: 700;
                        color: #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Title
                Text {
                    text: "Bedrud";
                    font-size: theme.font-2xl;
                    font-weight: 700;
                    color: theme.text-primary;
                    horizontal-alignment: center;
                }

                // Subtitle
                Text {
                    text: "Connect to your server";
                    font-size: theme.font-base;
                    color: theme.text-secondary;
                    horizontal-alignment: center;
                }

                // Spacer
                Rectangle { height: theme.space-sm; }

                // Error
                if add-instance-error != "": Rectangle {
                    background: #3f0000;
                    border-radius: theme.radius-md;
                    border-width: 1px;
                    border-color: theme.destructive;
                    height: 40px;
                    Text {
                        text: add-instance-error;
                        color: theme.destructive;
                        font-size: theme.font-sm;
                        wrap: word-wrap;
                        x: theme.space-sm;
                        y: theme.space-sm;
                    }
                }

                Input {
                    label: "Server URL";
                    placeholder: "https://bedrud.example.com";
                    value <=> add-instance-url;
                }

                Input {
                    label: "Label (optional)";
                    placeholder: "My Server";
                    value <=> add-instance-label;
                }

                // Spacer
                Rectangle { height: theme.space-xs; }

                Button {
                    text: "Connect";
                    clicked => { add-instance(add-instance-label, add-instance-url); }
                }
            }
        }
    }
}
