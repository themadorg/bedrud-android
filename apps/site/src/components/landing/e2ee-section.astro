---
import { Icon } from "astro-icon/components";
import { type Locale, t, getDir } from "../../i18n/utils";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const isRtl = getDir(lang) === "rtl";
---

<section class="section-y bg-background">
  <div class="section-container">
    <div class="mx-auto max-w-3xl text-center">
      <p
        data-animate="fade-up"
        class="text-[11px] font-semibold uppercase tracking-widest text-primary"
      >
        {t(lang, "e2eePage.badge")}
      </p>
      <h1
        data-animate="fade-up"
        class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
      >
        {t(lang, "e2eePage.title")}
      </h1>
      <p
        data-animate="fade-up"
        class="mt-4 text-lg text-muted-foreground"
        style="transition-delay: 80ms"
      >
        {t(lang, "e2eePage.subtitle")}
      </p>
    </div>
  </div>
</section>

<section class="section-y border-y border-border/40 bg-muted/30">
  <div class="section-container">
    <div class="mx-auto max-w-3xl">
      <h2
        data-animate="fade-up"
        class="text-2xl font-bold tracking-tight sm:text-3xl"
      >
        {t(lang, "e2eePage.howItWorks.title")}
      </h2>
      <p
        data-animate="fade-up"
        class="mt-3 text-muted-foreground"
        style="transition-delay: 80ms"
      >
        {t(lang, "e2eePage.howItWorks.description")}
      </p>

      <div class="mt-10 grid gap-8 sm:grid-cols-3">
        <div data-animate="fade-up" class="text-center border border-border bg-card p-6">
          <div class="mx-auto flex size-14 items-center justify-center bg-primary/10">
            <Icon name="lucide:lock" class="size-6 text-primary" stroke-width="1.5" />
          </div>
          <h3 class="mt-4 font-semibold">
            {t(lang, "e2eePage.howItWorks.step1.title")}
          </h3>
          <p class="mt-2 text-sm text-muted-foreground">
            {t(lang, "e2eePage.howItWorks.step1.description")}
          </p>
        </div>

        <div data-animate="fade-up" style="transition-delay: 80ms" class="text-center border border-border bg-card p-6">
          <div class="mx-auto flex size-14 items-center justify-center bg-primary/10">
            <Icon name="lucide:key-round" class="size-6 text-primary" stroke-width="1.5" />
          </div>
          <h3 class="mt-4 font-semibold">
            {t(lang, "e2eePage.howItWorks.step2.title")}
          </h3>
          <p class="mt-2 text-sm text-muted-foreground">
            {t(lang, "e2eePage.howItWorks.step2.description")}
          </p>
        </div>

        <div data-animate="fade-up" style="transition-delay: 160ms" class="text-center border border-border bg-card p-6">
          <div class="mx-auto flex size-14 items-center justify-center bg-primary/10">
            <Icon name="lucide:eye-off" class="size-6 text-primary" stroke-width="1.5" />
          </div>
          <h3 class="mt-4 font-semibold">
            {t(lang, "e2eePage.howItWorks.step3.title")}
          </h3>
          <p class="mt-2 text-sm text-muted-foreground">
            {t(lang, "e2eePage.howItWorks.step3.description")}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-y bg-background">
  <div class="section-container">
    <div class="mx-auto max-w-3xl">
      <h2
        data-animate="fade-up"
        class="text-2xl font-bold tracking-tight sm:text-3xl"
      >
        {t(lang, "e2eePage.zeroKnowledge.title")}
      </h2>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <div
          data-animate="fade-up"
          class="border border-border bg-card p-6"
        >
          <div class="flex items-center gap-2 text-primary">
            <Icon name="lucide:check-circle" class="size-5" stroke-width="1.5" />
            <h3 class="font-semibold">{t(lang, "e2eePage.zeroKnowledge.items.keyGen")}</h3>
          </div>
          <p class="mt-3 text-sm text-muted-foreground">{t(lang, "e2eePage.zeroKnowledge.items.keyGenDesc")}</p>
        </div>
        <div
          data-animate="fade-up"
          style="transition-delay: 80ms"
          class="border border-border bg-card p-6"
        >
          <div class="flex items-center gap-2 text-primary">
            <Icon name="lucide:check-circle" class="size-5" stroke-width="1.5" />
            <h3 class="font-semibold">{t(lang, "e2eePage.zeroKnowledge.items.blindRelay")}</h3>
          </div>
          <p class="mt-3 text-sm text-muted-foreground">{t(lang, "e2eePage.zeroKnowledge.items.blindRelayDesc")}</p>
        </div>
        <div
          data-animate="fade-up"
          style="transition-delay: 160ms"
          class="border border-border bg-card p-6"
        >
          <div class="flex items-center gap-2 text-primary">
            <Icon name="lucide:check-circle" class="size-5" stroke-width="1.5" />
            <h3 class="font-semibold">{t(lang, "e2eePage.zeroKnowledge.items.insertableStreams")}</h3>
          </div>
          <p class="mt-3 text-sm text-muted-foreground">{t(lang, "e2eePage.zeroKnowledge.items.insertableStreamsDesc")}</p>
        </div>
        <div
          data-animate="fade-up"
          style="transition-delay: 240ms"
          class="border border-border bg-card p-6"
        >
          <div class="flex items-center gap-2 text-primary">
            <Icon name="lucide:check-circle" class="size-5" stroke-width="1.5" />
            <h3 class="font-semibold">{t(lang, "e2eePage.zeroKnowledge.items.workerIsolation")}</h3>
          </div>
          <p class="mt-3 text-sm text-muted-foreground">{t(lang, "e2eePage.zeroKnowledge.items.workerIsolationDesc")}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- INTERACTIVE Packets flow visualizer section -->
<section class="section-y border-y border-border/40 bg-muted/30">
  <div class="section-container">
    <div class="mx-auto max-w-3xl">
      <h2
        data-animate="fade-up"
        class="text-2xl font-bold tracking-tight sm:text-3xl"
      >
        {t(lang, "e2eePage.architecture.title")}
      </h2>
      <p
        data-animate="fade-up"
        class="mt-3 text-muted-foreground"
        style="transition-delay: 80ms"
      >
        {t(lang, "e2eePage.architecture.description")}
      </p>

      <!-- Toggle Switch Control -->
      <div data-animate="fade-up" style="transition-delay: 120ms" class="mt-8 flex justify-center">
        <button
          id="e2ee-visual-toggle"
          class="group flex items-center justify-between gap-4 border border-border bg-background p-4 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 hover:bg-muted/40 cursor-pointer transition-colors"
          aria-label="Toggle encryption visualization mode"
        >
          <span class="font-semibold text-muted-foreground">{t(lang, "e2eePage.architecture.toggleLabel")}:</span>
          <div class="flex items-center gap-2">
            <span
              id="toggle-state-text"
              class="font-bold text-rose-500"
              data-disabled={t(lang, "e2eePage.architecture.disabledMode")}
              data-enabled={t(lang, "e2eePage.architecture.enabledMode")}
            >
              {t(lang, "e2eePage.architecture.disabledMode")}
            </span>
            <div class="relative w-12 h-6 border-2 border-border bg-muted flex items-center px-0.5 select-none">
              <div id="toggle-slider" class="w-4 h-4 bg-rose-500 transition-all duration-300" style="transform: translateX(0px)"></div>
            </div>
          </div>
        </button>
      </div>

      <!-- Visualization Canvas container -->
      <div
        data-animate="fade-up"
        style="transition-delay: 160ms"
        class="mt-6 border border-border bg-card p-6 font-mono text-sm overflow-hidden select-none"
      >
        <!-- Nodes layout -->
        <div class="grid gap-8 md:grid-cols-3 relative">
          <!-- Client A Node -->
          <div class="border border-border bg-background p-4 relative z-10 flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between pb-2 border-b border-border/60">
                <span class="text-xs font-bold text-primary">{t(lang, "e2eePage.architecture.sender")}</span>
                <span class="text-[10px] text-muted-foreground uppercase font-semibold">{t(lang, "e2eePage.architecture.clientA")}</span>
              </div>
              <div class="mt-3 flex items-center gap-3">
                <div class="size-10 bg-muted border border-border flex items-center justify-center font-bold text-primary text-lg">
                  A
                </div>
                <div class="text-xs leading-tight">
                  <p class="font-semibold">{t(lang, "e2eePage.architecture.mediaFeed")}</p>
                  <p class="text-muted-foreground font-mono" id="client-a-input">{t(lang, "e2eePage.architecture.frameSmile")}</p>
                </div>
              </div>
            </div>
            <div class="mt-6 pt-3 border-t border-border/40 text-xs">
              <p class="font-semibold text-muted-foreground mb-1 uppercase text-[9px] tracking-wider">{t(lang, "e2eePage.architecture.outboundPipeline")}:</p>
              <div
                id="client-a-pipeline"
                class="bg-muted p-2 font-mono text-[10px] text-rose-600 border border-rose-500/10"
                data-plaintext={t(lang, "e2eePage.architecture.plaintextPipeline")}
                data-encrypted={t(lang, "e2eePage.architecture.encryptPipeline")}
              >
                {t(lang, "e2eePage.architecture.plaintextPipeline")}
              </div>
            </div>
          </div>

          <!-- LiveKit SFU Node -->
          <div id="sfu-node" class="border border-border bg-background p-4 relative z-10 flex flex-col justify-between border-rose-200 dark:border-rose-950 transition-colors duration-300">
            <div>
              <div class="flex items-center justify-between pb-2 border-b border-border/60">
                <span
                  id="sfu-status-tag"
                  class="text-xs font-bold text-rose-500"
                  data-inspectable={t(lang, "e2eePage.architecture.inspectableStatus")}
                  data-blind={t(lang, "e2eePage.architecture.blindStatus")}
                >
                  {t(lang, "e2eePage.architecture.inspectableStatus")}
                </span>
                <span class="text-[10px] text-muted-foreground uppercase font-semibold">{t(lang, "e2eePage.architecture.sfuNode")}</span>
              </div>
              <div class="mt-3 flex items-center gap-3">
                <div id="sfu-icon-box" class="size-10 bg-rose-500/10 dark:bg-rose-500/15 border border-rose-500/20 flex items-center justify-center text-rose-500 transition-all duration-300">
                  <Icon name="lucide:server" class="size-5" />
                </div>
                <div class="text-xs leading-tight">
                  <p class="font-semibold">{t(lang, "e2eePage.architecture.relayDescription")}</p>
                  <p
                    class="text-muted-foreground"
                    id="sfu-inspection"
                    data-readable={t(lang, "e2eePage.architecture.readableServer")}
                    data-bypassed={t(lang, "e2eePage.architecture.bypassedServer")}
                  >
                    {t(lang, "e2eePage.architecture.readableServer")}
                  </p>
                </div>
              </div>
            </div>
            <div class="mt-6 pt-3 border-t border-border/40 text-xs">
              <p class="font-semibold text-muted-foreground mb-1 uppercase text-[9px] tracking-wider">{t(lang, "e2eePage.architecture.sfuStorage")}:</p>
              <div
                id="sfu-pipeline"
                class="bg-muted p-2 font-mono text-[10px] text-rose-500 border border-rose-500/10 overflow-hidden text-ellipsis whitespace-nowrap"
                data-clear={t(lang, "e2eePage.architecture.frameClear")}
                data-cipher={t(lang, "e2eePage.architecture.frameCipher")}
              >
                {t(lang, "e2eePage.architecture.frameClear")}
              </div>
            </div>
          </div>

          <!-- Client B Node -->
          <div class="border border-border bg-background p-4 relative z-10 flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between pb-2 border-b border-border/60">
                <span class="text-xs font-bold text-primary">{t(lang, "e2eePage.architecture.receiver")}</span>
                <span class="text-[10px] text-muted-foreground uppercase font-semibold">{t(lang, "e2eePage.architecture.clientB")}</span>
              </div>
              <div class="mt-3 flex items-center gap-3">
                <div class="size-10 bg-muted border border-border flex items-center justify-center font-bold text-primary text-lg">
                  B
                </div>
                <div class="text-xs leading-tight">
                  <p class="font-semibold">{t(lang, "e2eePage.architecture.decodedOutput")}</p>
                  <p class="text-emerald-600 dark:text-emerald-400 font-bold" id="client-b-output">{t(lang, "e2eePage.architecture.frameSmile")}</p>
                </div>
              </div>
            </div>
            <div class="mt-6 pt-3 border-t border-border/40 text-xs">
              <p class="font-semibold text-muted-foreground mb-1 uppercase text-[9px] tracking-wider">{t(lang, "e2eePage.architecture.inboundPipeline")}:</p>
              <div
                id="client-b-pipeline"
                class="bg-muted p-2 font-mono text-[10px] text-rose-600 border border-rose-500/10"
                data-plaintext={t(lang, "e2eePage.architecture.plaintextPipeline")}
                data-decrypted={t(lang, "e2eePage.architecture.decryptPipeline")}
              >
                {t(lang, "e2eePage.architecture.plaintextPipeline")}
              </div>
            </div>
          </div>

          <!-- Animated connecting paths (Desktops only, hidden on mobile) -->
          <div class="hidden md:block absolute top-[44px] start-[26%] w-[12%] h-[2px] bg-border z-0 overflow-hidden">
            <div id="packet-flow-1" class={isRtl ? "h-full w-4 bg-rose-500 animate-[flow-rtl_2s_infinite_linear]" : "h-full w-4 bg-rose-500 animate-[flow_2s_infinite_linear]"}></div>
          </div>
          <div class="hidden md:block absolute top-[44px] start-[61%] w-[12%] h-[2px] bg-border z-0 overflow-hidden">
            <div id="packet-flow-2" class={isRtl ? "h-full w-4 bg-rose-500 animate-[flow-rtl_2s_infinite_linear]" : "h-full w-4 bg-rose-500 animate-[flow_2s_infinite_linear]"}></div>
          </div>
        </div>

        <!-- Key Disclaimer Banner -->
        <div id="key-disclaimer-banner" class="mt-6 border border-border/60 bg-muted/20 p-3 text-xs flex items-start gap-2.5">
          <Icon name="lucide:info" class="size-4 shrink-0 text-muted-foreground mt-0.5" />
          <p
            class="text-muted-foreground font-sans text-xs leading-relaxed"
            data-standard={t(lang, "e2eePage.architecture.disclaimerStandard")}
            data-e2ee={t(lang, "e2eePage.architecture.disclaimerE2ee")}
          >
            {t(lang, "e2eePage.architecture.disclaimerStandard")}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-y bg-background">
  <div class="section-container">
    <div class="mx-auto max-w-3xl">
      <h2
        data-animate="fade-up"
        class="text-2xl font-bold tracking-tight sm:text-3xl"
      >
        {t(lang, "e2eePage.platforms.title")}
      </h2>
      <p
        data-animate="fade-up"
        class="mt-3 text-muted-foreground"
        style="transition-delay: 80ms"
      >
        {t(lang, "e2eePage.platforms.description")}
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div data-animate="fade-up" class="border border-border bg-card p-6 text-center">
          <Icon name="lucide:globe" class="mx-auto size-6 text-primary" stroke-width="1.5" />
          <p class="mt-3 font-semibold font-mono text-sm">{t(lang, "e2eePage.platforms.items.web")}</p>
        </div>
        <div data-animate="fade-up" style="transition-delay: 80ms" class="border border-border bg-card p-6 text-center">
          <Icon name="lucide:smartphone" class="mx-auto size-6 text-primary" stroke-width="1.5" />
          <p class="mt-3 font-semibold font-mono text-sm">{t(lang, "e2eePage.platforms.items.android")}</p>
        </div>
        <div data-animate="fade-up" style="transition-delay: 160ms" class="border border-border bg-card p-6 text-center">
          <Icon name="lucide:tablet" class="mx-auto size-6 text-primary" stroke-width="1.5" />
          <p class="mt-3 font-semibold font-mono text-sm">{t(lang, "e2eePage.platforms.items.ios")}</p>
        </div>
        <div data-animate="fade-up" style="transition-delay: 240ms" class="border border-border bg-card p-6 text-center">
          <Icon name="lucide:monitor" class="mx-auto size-6 text-primary" stroke-width="1.5" />
          <p class="mt-3 font-semibold font-mono text-sm">{t(lang, "e2eePage.platforms.items.desktop")}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-y border-y border-border/40 bg-muted/30">
  <div class="section-container">
    <div class="mx-auto max-w-3xl">
      <h2
        data-animate="fade-up"
        class="text-2xl font-bold tracking-tight sm:text-3xl"
      >
        {t(lang, "e2eePage.feature.title")}
      </h2>
      <p
        data-animate="fade-up"
        class="mt-3 text-muted-foreground"
        style="transition-delay: 80ms"
      >
        {t(lang, "e2eePage.feature.description")}
      </p>

      <div class="mt-8 space-y-4">
        <div data-animate="fade-up" class="flex items-start gap-4 border border-border bg-card p-5">
          <Icon name="lucide:check" class="mt-0.5 size-5 shrink-0 text-primary" stroke-width="2" />
          <div>
            <p class="font-semibold">{t(lang, "e2eePage.feature.items.perRoom.title")}</p>
            <p class="text-sm text-muted-foreground mt-1">{t(lang, "e2eePage.feature.items.perRoom.description")}</p>
          </div>
        </div>
        <div data-animate="fade-up" style="transition-delay: 80ms" class="flex items-start gap-4 border border-border bg-card p-5">
          <Icon name="lucide:check" class="mt-0.5 size-5 shrink-0 text-primary" stroke-width="2" />
          <div>
            <p class="font-semibold">{t(lang, "e2eePage.feature.items.zeroKnowledge.title")}</p>
            <p class="text-sm text-muted-foreground mt-1">{t(lang, "e2eePage.feature.items.zeroKnowledge.description")}</p>
          </div>
        </div>
        <div data-animate="fade-up" style="transition-delay: 160ms" class="flex items-start gap-4 border border-border bg-card p-5">
          <Icon name="lucide:check" class="mt-0.5 size-5 shrink-0 text-primary" stroke-width="2" />
          <div>
            <p class="font-semibold">{t(lang, "e2eePage.feature.items.noRecord.title")}</p>
            <p class="text-sm text-muted-foreground mt-1">{t(lang, "e2eePage.feature.items.noRecord.description")}</p>
          </div>
        </div>
        <div data-animate="fade-up" style="transition-delay: 240ms" class="flex items-start gap-4 border border-border bg-card p-5">
          <Icon name="lucide:check" class="mt-0.5 size-5 shrink-0 text-primary" stroke-width="2" />
          <div>
            <p class="font-semibold">{t(lang, "e2eePage.feature.items.openSource.title")}</p>
            <p class="text-sm text-muted-foreground mt-1">{t(lang, "e2eePage.feature.items.openSource.description")}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-y bg-background">
  <div class="section-container">
    <div class="mx-auto max-w-3xl text-center">
      <h2
        data-animate="fade-up"
        class="text-2xl font-bold tracking-tight sm:text-3xl"
      >
        {t(lang, "e2eePage.cta.title")}
      </h2>
      <p
        data-animate="fade-up"
        class="mt-3 text-muted-foreground"
        style="transition-delay: 80ms"
      >
        {t(lang, "e2eePage.cta.description")}
      </p>
      <div
        data-animate="fade-up"
        class="mt-8 flex flex-wrap items-center justify-center gap-4"
        style="transition-delay: 160ms"
      >
        <a
          href={`/${lang}/demo`}
          class="inline-flex items-center gap-2 bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          {t(lang, "e2eePage.cta.tryDemo")}
          <Icon name={isRtl ? "lucide:arrow-left" : "lucide:arrow-right"} class="size-4" stroke-width="2" />
        </a>
        <a
          href={`/${lang}/docs/architecture/e2ee`}
          class="inline-flex items-center gap-2 border border-border bg-card px-6 py-3 text-sm font-medium hover:bg-muted focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          {t(lang, "e2eePage.cta.readDocs")}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes flow {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(300%);
    }
  }
  @keyframes flow-rtl {
    0% {
      transform: translateX(100%);
    }
    100% {
      transform: translateX(-300%);
    }
  }
</style>

<script>
  // Simple state management for the interactive packet flow
  document.addEventListener("astro:page-load", () => {
    const button = document.getElementById("e2ee-visual-toggle");
    const toggleSlider = document.getElementById("toggle-slider");
    const toggleStateText = document.getElementById("toggle-state-text") as HTMLElement | null;
    const clientAPipeline = document.getElementById("client-a-pipeline") as HTMLElement | null;
    const clientBPipeline = document.getElementById("client-b-pipeline") as HTMLElement | null;
    const sfuNode = document.getElementById("sfu-node");
    const sfuStatusTag = document.getElementById("sfu-status-tag") as HTMLElement | null;
    const sfuIconBox = document.getElementById("sfu-icon-box");
    const sfuInspection = document.getElementById("sfu-inspection") as HTMLElement | null;
    const sfuPipeline = document.getElementById("sfu-pipeline") as HTMLElement | null;
    const clientBOutput = document.getElementById("client-b-output") as HTMLElement | null;
    const flow1 = document.getElementById("packet-flow-1");
    const flow2 = document.getElementById("packet-flow-2");
    const keyDisclaimer = document.querySelector("#key-disclaimer-banner p") as HTMLElement | null;

    if (
      !button ||
      !toggleSlider ||
      !toggleStateText ||
      !clientAPipeline ||
      !clientBPipeline ||
      !sfuNode ||
      !sfuStatusTag ||
      !sfuIconBox ||
      !sfuInspection ||
      !sfuPipeline ||
      !clientBOutput ||
      !flow1 ||
      !flow2 ||
      !keyDisclaimer
    ) {
      return;
    }

    let isE2ee = false;
    const isRtlToggle = document.documentElement.dir === "rtl";
    const toggleOnPos = isRtlToggle ? -24 : 24;

    button.addEventListener("click", () => {
      isE2ee = !isE2ee;

      if (isE2ee) {
        // Toggle Slider UI
        toggleSlider.style.transform = `translateX(${toggleOnPos}px)`;
        toggleSlider.classList.remove("bg-rose-500");
        toggleSlider.classList.add("bg-teal-500");
        toggleStateText.innerText = toggleStateText.dataset.enabled || "";
        toggleStateText.classList.remove("text-rose-500");
        toggleStateText.classList.add("text-teal-500");

        // Client A UI
        clientAPipeline.innerText = clientAPipeline.dataset.encrypted || "";
        clientAPipeline.classList.remove("text-rose-600", "border-rose-500/10");
        clientAPipeline.classList.add("text-teal-600", "dark:text-teal-400", "border-teal-500/10");

        // SFU Node UI
        sfuNode.classList.remove("border-rose-200", "dark:border-rose-950");
        sfuNode.classList.add("border-teal-500/30", "dark:border-teal-950");
        sfuStatusTag.innerText = sfuStatusTag.dataset.blind || "";
        sfuStatusTag.classList.remove("text-rose-500");
        sfuStatusTag.classList.add("text-teal-500");

        sfuIconBox.classList.remove("bg-rose-500/10", "dark:bg-rose-500/15", "border-rose-500/20", "text-rose-500");
        sfuIconBox.classList.add("bg-teal-500/10", "dark:bg-teal-500/15", "border-teal-500/20", "text-teal-500");
        sfuInspection.innerText = sfuInspection.dataset.bypassed || "";
        sfuPipeline.innerText = sfuPipeline.dataset.cipher || "";
        sfuPipeline.classList.remove("text-rose-500", "border-rose-500/10");
        sfuPipeline.classList.add("text-teal-500", "border-teal-500/10");

        // Client B UI
        clientBPipeline.innerText = clientBPipeline.dataset.decrypted || "";
        clientBPipeline.classList.remove("text-rose-600", "border-rose-500/10");
        clientBPipeline.classList.add("text-teal-600", "dark:text-teal-400", "border-teal-500/10");

        // Packet Flow animation colors
        flow1.classList.remove("bg-rose-500");
        flow1.classList.add("bg-teal-500");
        flow2.classList.remove("bg-rose-500");
        flow2.classList.add("bg-teal-500");

        // Key disclaimer explanation update
        keyDisclaimer.innerText = keyDisclaimer.dataset.e2ee || "";
      } else {
        // Toggle Slider UI
        toggleSlider.style.transform = "translateX(0px)";
        toggleSlider.classList.remove("bg-teal-500");
        toggleSlider.classList.add("bg-rose-500");
        toggleStateText.innerText = toggleStateText.dataset.disabled || "";
        toggleStateText.classList.remove("text-teal-500");
        toggleStateText.classList.add("text-rose-500");

        // Client A UI
        clientAPipeline.innerText = clientAPipeline.dataset.plaintext || "";
        clientAPipeline.classList.add("text-rose-600", "border-rose-500/10");
        clientAPipeline.classList.remove("text-teal-600", "dark:text-teal-400", "border-teal-500/10");

        // SFU Node UI
        sfuNode.classList.add("border-rose-200", "dark:border-rose-950");
        sfuNode.classList.remove("border-teal-500/30", "dark:border-teal-950");
        sfuStatusTag.innerText = sfuStatusTag.dataset.inspectable || "";
        sfuStatusTag.classList.add("text-rose-500");
        sfuStatusTag.classList.remove("text-teal-500");

        sfuIconBox.classList.add("bg-rose-500/10", "dark:bg-rose-500/15", "border-rose-500/20", "text-rose-500");
        sfuIconBox.classList.remove("bg-teal-500/10", "dark:bg-teal-500/15", "border-teal-500/20", "text-teal-500");
        sfuInspection.innerText = sfuInspection.dataset.readable || "";
        sfuPipeline.innerText = sfuPipeline.dataset.clear || "";
        sfuPipeline.classList.add("text-rose-500", "border-rose-500/10");
        sfuPipeline.classList.remove("text-teal-500", "border-teal-500/10");

        // Client B UI
        clientBPipeline.innerText = clientBPipeline.dataset.plaintext || "";
        clientBPipeline.classList.add("text-rose-600", "border-rose-500/10");
        clientBPipeline.classList.remove("text-teal-600", "dark:text-teal-400", "border-teal-500/10");

        // Packet Flow animation colors
        flow1.classList.add("bg-rose-500");
        flow1.classList.remove("bg-teal-500");
        flow2.classList.add("bg-rose-500");
        flow2.classList.remove("bg-teal-500");

        // Key disclaimer explanation update
        keyDisclaimer.innerText = keyDisclaimer.dataset.standard || "";
      }
    });
  });
</script>
