---
import Base from "./Base.astro";
import { LanguageSwitcher } from "~/components/landing/language-switcher";
import { Sidebar } from "~/components/docs/sidebar";
import { ThemeToggle } from "~/components/landing/theme-toggle";
import { Toc } from "~/components/docs/toc";
import { DocsMobileSidebar } from "~/components/docs/docs-mobile-sidebar";
import { Search } from "~/components/docs/search";
import { isValidLocale, type Locale, t } from "../i18n/utils";
import { DocsHeaderStars } from "~/components/docs/docs-header-stars";
import { Footer } from "~/components/landing/footer";


interface Props {
  lang: string;
  title?: string;
  description?: string;
  currentSlug?: string;
  image?: string;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    authors?: string[];
    tags?: string[];
  };
  headLinks?: { rel: string; href: string }[];
  jsonLd?: Record<string, unknown>[];
  hideToc?: boolean;
}

const {
  lang: rawLang = "en",
  title,
  description,
  currentSlug = "",
  image,
  article,
  headLinks = [],
  jsonLd,
  hideToc = false,
} = Astro.props;
const lang: Locale = isValidLocale(rawLang) ? rawLang : "en";
---

<Base lang={lang} title={title} description={description} image={image} article={article} headLinks={headLinks} jsonLd={jsonLd}>
  <div class="min-h-screen bg-background">
    <header class="fixed inset-x-0 top-0 z-40 border-b bg-background/80 backdrop-blur-sm">
      <div class="mx-auto flex h-16 items-center gap-2 sm:gap-4 px-4 sm:px-6 lg:max-w-7xl xl:max-w-[100rem] lg:px-8">
        <DocsMobileSidebar client:idle lang={lang} currentSlug={currentSlug} />
        <div class="flex items-center gap-3">
          <a href={`/${lang}`} class="gap-2 text-sm">
            <span class="font-semibold">Bedrud</span>
          </a>
          <span class="text-sm text-muted-foreground">{t(lang, "nav.docs")}</span>
        </div>
        <nav class="hidden md:flex items-center gap-0.5 ms-4">
          <a href={`/${lang}/features`}
             class="rounded-full px-3.5 py-1.5 text-[13px] font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
            {t(lang, "nav.features")}
          </a>
          <a href={`/${lang}/download`}
             class="rounded-full px-3.5 py-1.5 text-[13px] font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
            {t(lang, "nav.download")}
          </a>
          <a href={`/${lang}/docs`}
             class="rounded-full px-3.5 py-1.5 text-[13px] font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
            {t(lang, "nav.docs")}
          </a>
        </nav>
        <div class="ms-0 lg:ms-auto flex items-center gap-3 pe-1">
          <div class="hidden lg:block">
            <Search client:idle lang={lang} />
          </div>
          <ThemeToggle client:load lang={lang} />
          <LanguageSwitcher client:load lang={lang} />
          <div class="hidden lg:flex">
            <DocsHeaderStars client:load />
          </div>
        </div>
      </div>
    </header>

    <div class="pt-16">
      <div class="mx-auto max-w-7xl xl:max-w-[100rem]">
        <div class={`grid grid-cols-1 gap-6 lg:grid-cols-[240px_1fr] lg:gap-8 ${hideToc ? 'xl:grid-cols-[260px_1fr]' : 'xl:grid-cols-[260px_1fr_240px]'}`}>
          <div class="hidden lg:block lg:sticky lg:top-16 lg:self-start">
            <Sidebar client:idle lang={lang} currentSlug={currentSlug} />
          </div>
          <div>
            <main id="main-content" class="min-h-screen flex-1 px-4 sm:px-6 lg:px-8 py-10 lg:py-16 max-w-4xl xl:max-w-none">
              <slot />
            </main>
          </div>
          {!hideToc && (
            <div class="hidden xl:block xl:col-span-1 xl:sticky xl:top-16 xl:self-start">
              <Toc client:idle lang={lang} />
            </div>
          )}
        </div>
      </div>
    </div>

    <Footer client:load lang={lang} />
  </div>
</Base>
