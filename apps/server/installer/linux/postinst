#!/bin/sh
set -e

# Create bedrud system user if it doesn't exist
if ! getent passwd bedrud > /dev/null 2>&1; then
    useradd -r -s /usr/sbin/nologin -d /var/lib/bedrud bedrud
fi

# Create runtime directories
mkdir -p /etc/bedrud /var/lib/bedrud /var/log/bedrud
chown -R bedrud:bedrud /var/lib/bedrud /var/log/bedrud

# Enable systemd units (bedrud + embedded LiveKit via livekit.service)
if command -v systemctl > /dev/null 2>&1 && systemctl is-system-running --quiet 2>/dev/null; then
    systemctl daemon-reload
    systemctl enable livekit.service bedrud.service || true

    # Restart on upgrade when configs already exist; first install needs
    # `bedrud install` (or manual config) to generate secrets + livekit.yaml.
    if [ -f /etc/bedrud/config.yaml ] && [ -f /etc/bedrud/livekit.yaml ]; then
        systemctl restart livekit.service bedrud.service || true
    fi
fi

if [ ! -f /etc/bedrud/config.yaml ] || [ ! -f /etc/bedrud/livekit.yaml ]; then
    echo ""
    echo "Bedrud installed. Generate config + LiveKit setup, then start services:"
    echo "  sudo bedrud install"
    echo ""
    echo "That writes /etc/bedrud/config.yaml and /etc/bedrud/livekit.yaml,"
    echo "and enables livekit.service (embedded LiveKit from the bedrud binary)"
    echo "plus bedrud.service."
    echo ""
    echo "Docs: https://themadorg.github.io/bedrud/getting-started/installation/"
else
    echo ""
    echo "Bedrud package upgraded. Services livekit + bedrud were restarted if systemd is available."
    echo "To run database/version migrations explicitly: sudo bedrud update --skip-binary"
fi
