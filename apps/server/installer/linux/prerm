#!/bin/sh
set -e

# Stop services before package removal/upgrade so the binary can be replaced
if command -v systemctl > /dev/null 2>&1; then
    systemctl stop bedrud.service livekit.service 2>/dev/null || true
fi

if [ "$1" = "remove" ]; then
    if command -v systemctl > /dev/null 2>&1; then
        systemctl disable bedrud.service livekit.service 2>/dev/null || true
    fi
fi
